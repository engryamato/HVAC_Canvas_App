# Local Development Environment Configuration
# Copy this file to .env.local for local development
# .env.local is gitignored and will override .env.example values

# App Configuration
NEXT_PUBLIC_APP_NAME=SizeWise HVAC Canvas
NEXT_PUBLIC_APP_VERSION=0.1.0-dev

# Feature Flags - Development Settings
# Enable features as needed for development/testing
NEXT_PUBLIC_ENABLE_WEATHER_API=false
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_CLOUD_SYNC=false

# Workstream Feature Flags (src/core/flags/featureFlags.ts)
# All default ON. Set a flag to exactly "false" to disable it; any other value
# (or unset) leaves it enabled. These are read as static NEXT_PUBLIC_FF_*
# literals so webpack inlines them at build time.
# NEXT_PUBLIC_FF_WS1_SINGLE_TOOLBAR=false
# NEXT_PUBLIC_FF_WS2_INLINE_TOOL_OPTIONS=false
# NEXT_PUBLIC_FF_WS3_CAS=false
# NEXT_PUBLIC_FF_WS5_MANUAL_SIZING_PROVENANCE=false
# NEXT_PUBLIC_FF_WS7_BOM_PRICING=false
# NEXT_PUBLIC_FF_WS6_CONSTRUCTION_DERIVATION=false
# NEXT_PUBLIC_FF_WS7_WEIGHT_PRICING=false

# Development Settings
NEXT_PUBLIC_DEBUG_MODE=true
NODE_ENV=development

# Optional: Local API endpoints for development
# NEXT_PUBLIC_API_URL=http://localhost:3000
# NEXT_PUBLIC_TAURI_API_URL=http://localhost:1420

# Optional: Feature toggles for testing
# NEXT_PUBLIC_ENABLE_EXPERIMENTAL_FEATURES=true
